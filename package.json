{
  "name": "save-bot",
  "version": "1.0.0",
  "description": "Telegram save bot for downloading media from social platforms",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node src/index.js",
    "dev:watch": "node --watch-path=./src --watch-preserve-output ./src/index.js",
    "stop": "node scripts/stop-bot.js",
    "start": "node src/index.js",
    "start:prod": "NODE_ENV=production node src/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart save-bot",
    "pm2:logs": "pm2 logs save-bot",
    "lint": "echo \"No linter configured\""
  },
  "keywords": [
    "telegram",
    "bot",
    "instagram",
    "facebook",
    "youtube",
    "downloader"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "dotenv": "^16.6.1",
    "p-limit": "^3.1.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
